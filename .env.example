# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# API server
API_PORT=8080
ENABLE_DEMO_AUTH=true

# Expo public runtime
EXPO_PUBLIC_DOMAIN=localhost:8080
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_USE_REMOTE_API=false
EXPO_PUBLIC_REPL_ID=
EXPO_PUBLIC_ENABLE_DEMO_AUTH=true

# Cloudinary unsigned upload configuration
# Use a locked-down unsigned upload preset in development only.
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Optional deployment path prefix
BASE_PATH=/
